# App Settings
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=automation_db

# JWT Settings
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Instagram OAuth
INSTAGRAM_CLIENT_ID=your-instagram-app-id
INSTAGRAM_CLIENT_SECRET=your-instagram-app-secret
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/v1/instagram/callback

# Instagram Graph API
INSTAGRAM_GRAPH_API_URL=https://graph.instagram.com

# Encryption key for storing access tokens (32 bytes base64 encoded)
ENCRYPTION_KEY=your-32-byte-base64-encoded-key-here

# Logging
LOG_LEVEL=INFO

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin123@localhost:5672/

# Resend (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=onboarding@resend.dev
RESEND_FROM_NAME=CreatorModo
RESEND_REPLY_TO=

# Brand context (injected into every email template render)
BRAND_PRODUCT_NAME=CreatorModo
BRAND_COMPANY_ADDRESS=creatormodo.com
BRAND_HELP_URL=https://creatormodo.com/help
BRAND_PRIVACY_URL=https://creatormodo.com/privacy
BRAND_TERMS_URL=https://creatormodo.com/terms
BRAND_UNSUBSCRIBE_URL=

# Token expiries / cooldowns
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_COOLDOWN_SECONDS=60
PASSWORD_RESET_MAX_ACTIVE_TOKENS=3

# Email dispatcher (worker process)
EMAIL_DISPATCH_BATCH_SIZE=25
EMAIL_DISPATCH_INTERVAL_SECONDS=5
EMAIL_MAX_RETRIES=5
EMAIL_DISPATCH_CONCURRENCY=5
