{% extends "emails/_base.html.j2" %}

{% block title %}Instagram connected to {{ product_name }}{% endblock %}

{% block preheader %}@{{ instagram_handle }} is now connected. You can build automations.{% endblock %}

{% block card %}
<!-- Eyebrow with sage dot -->
<tr>
  <td class="px" style="padding:40px 40px 0 40px;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td valign="middle" style="padding:0 8px 0 0; line-height:0;">
          <div style="width:8px; height:8px; background:#7D9B76; border-radius:9999px; line-height:0; font-size:0;">&nbsp;</div>
        </td>
        <td valign="middle">
          <span style="display:inline-block; font-size:12px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; color:#7D9B76;">Account Connected</span>
        </td>
      </tr>
    </table>
  </td>
</tr>

<!-- Headline -->
<tr>
  <td class="px" style="padding:12px 40px 0 40px;">
    <h1 style="margin:0; font-size:24px; line-height:1.15; font-weight:700; letter-spacing:-0.01em; color:#1A1B1E;">
      Your Instagram account is connected.
    </h1>
  </td>
</tr>

<!-- Body -->
<tr>
  <td class="px" style="padding:16px 40px 0 40px;">
    <p style="margin:0; font-size:14px; line-height:1.6; color:#1A1B1E;">
      Hi {{ user_first_name }} — {{ product_name }} is now linked to your Instagram. You can start building automations and tracking analytics for your posts.
    </p>
  </td>
</tr>

<!-- Account chip -->
<tr>
  <td class="px" style="padding:24px 40px 0 40px;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#E8E6E3; border:1px solid #C9C7C4; border-radius:10px;">
      <tr>
        <td valign="middle" style="padding:14px 16px;">
          <table role="presentation" cellpadding="0" cellspacing="0" border="0">
            <tr>
              <td valign="middle" style="padding:0 12px 0 0;">
                <div style="width:36px; height:36px; line-height:36px; text-align:center; background:#B8963A; border-radius:9999px; color:#FDFCFB; font-size:14px; font-weight:600;">{{ instagram_handle[0]|upper }}</div>
              </td>
              <td valign="middle">
                <p style="margin:0; font-size:14px; line-height:1.3; font-weight:600; color:#1A1B1E;">@{{ instagram_handle }}</p>
                <p style="margin:2px 0 0 0; font-size:12px; line-height:1.3; color:#5C5A57;">{{ connected_label }} · {{ account_type }} account</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </td>
</tr>

<!-- CTA -->
<tr>
  <td class="px" style="padding:24px 40px 0 40px;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="btn">
      <tr>
        <td align="center" style="background:#B8963A; border-radius:8px;">
          <!--[if mso]>
          <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="{{ create_automation_url }}" style="height:40px;v-text-anchor:middle;width:240px;" arcsize="20%" stroke="f" fillcolor="#B8963A">
            <w:anchorlock/>
            <center style="color:#FDFCFB;font-family:Arial,sans-serif;font-size:14px;font-weight:600;">Create Your First Automation</center>
          </v:roundrect>
          <![endif]-->
          <!--[if !mso]><!-- -->
          <a href="{{ create_automation_url }}"
             style="display:inline-block; padding:11px 22px; font-size:14px; font-weight:600; color:#FDFCFB; line-height:1.2; border-radius:8px;">
            Create Your First Automation
          </a>
          <!--<![endif]-->
        </td>
      </tr>
    </table>
  </td>
</tr>

<!-- What you can do -->
<tr>
  <td class="px" style="padding:32px 40px 0 40px;">
    <p style="margin:0 0 12px 0; font-size:12px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; color:#5C5A57;">
      What you can do now
    </p>

    {% set capabilities = capabilities or [
      {"title": "Auto‑DM commenters", "body": "send a message when someone comments on a post."},
      {"title": "Reply publicly",     "body": "pair DMs with an automatic comment reply."},
      {"title": "Track performance",  "body": "DMs sent, people reached, top automations."}
    ] %}

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
      {% for c in capabilities %}
      <tr>
        <td valign="top" style="padding:8px 0; border-top:1px solid #C9C7C4;{% if loop.last %} border-bottom:1px solid #C9C7C4;{% endif %}">
          <p style="margin:0; font-size:14px; line-height:1.5; color:#1A1B1E;">
            <span style="font-weight:600;">{{ c.title }}</span>
            <span style="color:#5C5A57;"> — {{ c.body }}</span>
          </p>
        </td>
      </tr>
      {% endfor %}
    </table>
  </td>
</tr>

<!-- Security -->
<tr>
  <td class="px" style="padding:28px 40px 40px 40px;">
    <p style="margin:0; font-size:12px; line-height:1.6; color:#5C5A57;">
      Wasn't you? <a href="{{ disconnect_url }}" style="color:#C48B8B; text-decoration:underline; font-weight:500;">Disconnect this account</a> right away and reset your password.
    </p>
  </td>
</tr>
{% endblock %}
